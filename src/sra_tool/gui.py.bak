        ttk.Label(openalex_box, text="Pegue una URL directa de OpenAlex o una query traducible:").pack(anchor="w")
        self.openalex_text = tk.Text(openalex_box, height=4, wrap="word")
        self.openalex_text.pack(fill="x", expand=True, pady=(6, 6))

