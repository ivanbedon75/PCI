        ttk.Label(row2, text="CSV Scopus exploratory:", width=20).pack(side="left")
        ttk.Entry(row2, textvariable=self.scopus_exploratory_path).pack(side="left", fill="x", expand=True, padx=6)
        ttk.Button(row2, text="Cargar...", command=self._select_scopus_exploratory_csv).pack(side="left")

