   def _build_tab6(self) -> None:
       frame = self._build_stage_panel(self.tab6, "6. Síntesis", "Prepara artefactos para síntesis sin relanzar toda la cadena.")
       box = ttk.LabelFrame(frame, text="Proceso de etapa 6", padding=10)
